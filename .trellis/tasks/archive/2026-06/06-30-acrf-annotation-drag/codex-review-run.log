   211	def test_import_rejects_non_sqlite_file(client, engine, tmp_path):
   212	    """非 SQLite 文件应返回 400。"""
   213	    token = login_as(client, "admin")
   214	    fake = tmp_path / "fake.db"
   215	    fake.write_bytes(b"This is not a SQLite file at all")
   216	    resp = _upload_db(client, "/api/projects/import/project-db", fake, token)
   217	    assert resp.status_code == 400
   218	    assert "SQLite" in resp.json()["detail"]
