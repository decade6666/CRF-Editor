   106	def _open_readonly_sqlite(file_path: str) -> Session:
   107	    """打开外部 SQLite 文件为只读 Session（支持中文路径）。"""
   108	    path = Path(file_path)
   109	    if not path.exists():
   110	        raise FileNotFoundError(f"文件不存在: {file_path}")
   111	
   112	    db_path = str(path.resolve())
   113	
   114	    engine = create_engine(
   115	        "sqlite+pysqlite://",
   116	        creator=lambda: sqlite3.connect(db_path, check_same_thread=False),
   117	    )
   118	
   119	    @event.listens_for(engine, "connect")
   120	    def _set_readonly(dbapi_conn, connection_record):
   121	        dbapi_conn.execute("PRAGMA query_only = ON")
   122	
   123	    return sessionmaker(bind=engine)()
   124	
   125	
   126	def _validate_schema(ext_session: Session) -> None:
   127	    """校验外部数据库包含所有核心表及关键列。"""
   128	    result = ext_session.execute(text("SELECT name FROM sqlite_master WHERE type='table'"))
   129	    existing = {row[0] for row in result}
   130	    missing = _REQUIRED_TABLES - existing
   131	    if missing:
   132	        raise ValueError(f"数据库缺少核心表: {', '.join(sorted(missing))}")
   133	
   134	    inspector = inspect(ext_session.get_bind())
   135	    incompatible: list[str] = []
   136	    for table_name, required_columns in _REQUIRED_COLUMNS.items():
   137	        existing_columns = {col["name"] for col in inspector.get_columns(table_name)}
   138	        effective_required_columns = set(required_columns)
   139	        if table_name == "project":
   140	            effective_required_columns.discard("screening_number_format")

