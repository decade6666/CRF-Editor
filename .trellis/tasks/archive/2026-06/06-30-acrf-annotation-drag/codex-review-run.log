   222	def _compare_row_cells(
   223	    mismatches: list[CellMismatch],
   224	    form_index: int,
   225	    form_name: str,
   226	    table_index: int,
   227	    row_index: int,
   228	    preview_row: list[str] | None,
   229	    export_row: list[str] | None,
   230	    max_mismatches: int,
   231	) -> int:
   232	    exact_cells = 0
   233	    for cell_index in range(max(len(preview_row or []), len(export_row or []))):
   234	        preview_cell = _get_item(preview_row or [], cell_index)
   235	        export_cell = _get_item(export_row or [], cell_index)
   236	        if preview_cell == export_cell and preview_cell is not None:
   237	            exact_cells += 1
   238	        elif len(mismatches) < max_mismatches:
   239	            mismatches.append(_cell_mismatch(
   240	                form_index, form_name, table_index, row_index, cell_index, preview_cell, export_cell
   241	            ))
   242	    return exact_cells
   243	
