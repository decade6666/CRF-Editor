     1	// 解析后端错误响应
     2	// 兼容 FastAPI/Pydantic 的数组型 detail（422 Unprocessable Content）
     3	async function _parseError(r) {
     4	  const text = await r.text();
     5	  try {
     6	    const j = JSON.parse(text);
     7	    const detail = j.detail;
     8	    if (!detail) return text;
     9	    // Pydantic 验证错误：detail 是数组，每项含 loc/msg/type
    10	    if (Array.isArray(detail)) {
    11	      return detail
    12	        .map((e) => {
    13	          const loc = Array.isArray(e.loc) ? e.loc.join(' → ') : '';
    14	          return loc ? `${loc}: ${e.msg}` : e.msg;
    15	        })
    16	        .join('；');
    17	    }
    18	    // 普通字符串 detail
    19	    return typeof detail === 'string' ? detail : text;
    20	  } catch {
    21	    return text;
    22	  }
    23	}
