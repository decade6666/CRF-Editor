   146	      body: JSON.stringify(data),
   147	    });
   148	    await _checkStatus(r);
   149	    _autoInvalidate(url);
   150	    return r.status === 204 ? null : _safeJsonParse(r);
   151	  },
   152	  async put(url, data) {
