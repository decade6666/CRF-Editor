   170	    token = login_as(client, "bob")
   171	    annotation_positions = '{"_form":{"y":18},"VAR0":{"y":-24}}'
   172	    db_path = _create_export_db(
   173	        tmp_path / "annotation_export.db",
   174	        project_count=1,
   175	        with_children=True,
   176	        annotation_positions=annotation_positions,
   177	    )
   178	    resp = _upload_db(client, "/api/projects/import/project-db", db_path, token)
   179	    assert resp.status_code == 200, resp.text
   180	
   181	    with Session(engine) as session:
   182	        imported_form = session.scalar(
   183	            select(Form).where(Form.project_id == resp.json()["project_id"])
   184	        )
   185	        assert imported_form is not None
   186	        assert imported_form.annotation_positions == annotation_positions
