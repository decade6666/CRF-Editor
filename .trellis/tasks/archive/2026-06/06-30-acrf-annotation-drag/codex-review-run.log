   133	def compare_table_field_forms(
   134	    preview_forms: list[TableFieldForm],
   135	    export_forms: list[TableFieldForm],
   136	    *,
   137	    max_mismatches: int = 100,
   138	) -> TableFieldParityReport:
   139	    exact_cells = 0
   140	    exact_rows = 0
   141	    mismatches: list[CellMismatch] = []
   142	
   143	    for form_index in range(max(len(preview_forms), len(export_forms))):
   144	        preview_form = _get_item(preview_forms, form_index)
   145	        export_form = _get_item(export_forms, form_index)
   146	        form_name = _form_name(preview_form, export_form)
   147	        for table_index in range(max(_table_count(preview_form), _table_count(export_form))):
   148	            preview_table = _get_table(preview_form, table_index)
   149	            export_table = _get_table(export_form, table_index)
   150	            for row_index in range(max(len(preview_table), len(export_table))):
   151	                preview_row = _get_item(preview_table, row_index)
   152	                export_row = _get_item(export_table, row_index)
   153	                if preview_row is not None and export_row is not None and preview_row == export_row:
   154	                    exact_rows += 1
   155	                exact_cells += _compare_row_cells(
   156	                    mismatches,
   157	                    form_index,
   158	                    form_name,
   159	                    table_index,
   160	                    row_index,
   161	                    preview_row,
   162	                    export_row,
   163	                    max_mismatches,
   164	                )
   165	
   166	    return TableFieldParityReport(
   167	        preview_form_count=len(preview_forms),
   168	        export_form_count=len(export_forms),
   169	        form_order_matches=[form.name for form in preview_forms] == [form.name for form in export_forms],
   170	        preview_row_count=_count_rows(preview_forms),
   171	        export_row_count=_count_rows(export_forms),
   172	        preview_cell_count=_count_cells(preview_forms),
   173	        export_cell_count=_count_cells(export_forms),
   174	        exact_cell_count=exact_cells,
   175	        exact_row_count=exact_rows,
   176	        mismatches=mismatches,
   177	    )
