   100	def load_preview_table_fields(source: str | Path | list[Any] | dict[str, Any]) -> list[TableFieldForm]:
   101	    if isinstance(source, str | Path):
   102	        raw = json.loads(Path(source).read_text(encoding="utf-8"))
   103	    else:
   104	        raw = source
   105	
   106	    raw_forms = raw.get("forms") if isinstance(raw, dict) else raw
   107	    if not isinstance(raw_forms, list):
   108	        raise ValueError("preview table fields must be a list or an object with a forms list")
   109	
   110	    return [_parse_form(raw_form, index) for index, raw_form in enumerate(raw_forms)]
   111	
   112	
   113	def extract_docx_form_table_fields(docx_path: str | Path) -> list[TableFieldForm]:
   114	    doc = Document(str(docx_path))
   115	    forms: list[TableFieldForm] = []
   116	    current_form: TableFieldForm | None = None
   117	
   118	    for block in _iter_block_items(doc):
   119	        if isinstance(block, Paragraph):
   120	            # 跳过含域代码的段落（如 TOC 预渲染条目），避免误判为表单标题
   121	            if _has_field_codes(block):
   122	                continue
   123	            match = FORM_HEADING_RE.match(block.text.strip())
   124	            if match:
   125	                current_form = TableFieldForm(name=match.group(1), tables=[])
   126	                forms.append(current_form)
   127	        elif isinstance(block, Table) and current_form is not None:
   128	            current_form.tables.append(_extract_table(block))
   129	
   130	    return forms
