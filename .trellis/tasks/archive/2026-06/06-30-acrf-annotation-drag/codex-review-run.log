    58	def _patch_legacy_project_schema(file_path: str) -> None:
    59	    """为旧版项目库补齐导入所需的新增列，仅修改临时副本。"""
    60	    conn = sqlite3.connect(file_path)
    61	    try:
    62	        tables = {row[0] for row in conn.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()}
    63	        if 'project' in tables:
    64	            cols = {row[1] for row in conn.execute("PRAGMA table_info(project)").fetchall()}
    65	            if 'screening_number_format' not in cols:
    66	                conn.execute('ALTER TABLE project ADD COLUMN screening_number_format VARCHAR(100)')
    67	        if 'form' in tables:
    68	            cols = {row[1] for row in conn.execute("PRAGMA table_info(form)").fetchall()}
    69	            if 'annotation_positions' not in cols:
    70	                conn.execute("ALTER TABLE form ADD COLUMN annotation_positions TEXT")
    71	            if 'paper_orientation' not in cols:
    72	                conn.execute(
    73	                    "ALTER TABLE form ADD COLUMN paper_orientation VARCHAR(16) "
    74	                    "NOT NULL DEFAULT 'auto'"
    75	                )
    76	        if 'form_field' in tables:
    77	            cols = {row[1] for row in conn.execute("PRAGMA table_info(form_field)").fetchall()}
    78	            if 'label_bold' not in cols:
    79	                conn.execute('ALTER TABLE form_field ADD COLUMN label_bold INTEGER NOT NULL DEFAULT 1')
    80	            if 'label_font_size' not in cols:
    81	                conn.execute('ALTER TABLE form_field ADD COLUMN label_font_size VARCHAR(10) DEFAULT NULL')
    82	        conn.commit()
    83	    finally:
    84	        conn.close()
