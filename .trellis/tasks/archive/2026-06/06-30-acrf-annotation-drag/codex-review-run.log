   108	// API 请求工具
   109	export const api = {
   110	  async get(url) {
   111	    const r = await fetch(url, { headers: _getAuthHeaders() });
   112	    await _checkStatus(r);
   113	    return _safeJsonParse(r);
   114	  },
   115	
   116	  // 带缓存的GET，TTL默认30秒
   117	  async cachedGet(url, ttl = 30000) {
   118	    const cached = _cache.get(url);
   119	    if (cached && Date.now() - cached.ts < ttl) return cached.data;
   120	
   121	    // Promise去重：同一URL并发只发一次请求
   122	    if (_pending.has(url)) return _pending.get(url);
   123	
   124	    const p = fetch(url, { headers: _getAuthHeaders() })
   125	      .then(async (r) => {
   126	        await _checkStatus(r);
   127	        const data = await _safeJsonParse(r);
   128	        _cache.set(url, { data, ts: Date.now() });
   129	        _pending.delete(url);
   130	        return data;
   131	      })
   132	      .catch((err) => {
   133	        _pending.delete(url);
   134	        throw err;
   135	      });
   136	    _pending.set(url, p);
   137	    return p;
   138	  },
