    30	        company_logo_path="source-logo.png",
    31	    )
    32	    session.add(project)
    33	    session.flush()
    34	
    35	    unit = Unit(project_id=project.id, symbol="kg", code="UNIT_KG", order_index=1)
    36	    session.add(unit)
    37	    session.flush()
    38	
    39	    codelist = CodeList(project_id=project.id, name="性别", code="CL_SEX", description="desc", order_index=1)
    40	    session.add(codelist)
    41	    session.flush()
    42	
    43	    opt1 = CodeListOption(codelist_id=codelist.id, code="1", decode="男", trailing_underscore=0, order_index=1)
    44	    opt2 = CodeListOption(codelist_id=codelist.id, code="2", decode="女", trailing_underscore=1, order_index=2)
    45	    session.add_all([opt1, opt2])
    46	    session.flush()
    47	
    48	    fd1 = FieldDefinition(
    49	        project_id=project.id,
    50	        variable_name="WEIGHT",
    51	        label="体重",
    52	        field_type="数值",
    53	        unit_id=unit.id,
    54	        order_index=1,
    55	    )
    56	    fd2 = FieldDefinition(
    57	        project_id=project.id,
    58	        variable_name="SEX",
    59	        label="性别",
    60	        field_type="单选",
    61	        codelist_id=codelist.id,
    62	        order_index=2,
    63	    )
    64	    session.add_all([fd1, fd2])
    65	    session.flush()
    66	
    67	    form = Form(
    68	        project_id=project.id,
    69	        name="筛选表",
    70	        code="FORM001",
    71	        domain="DM",
    72	        order_index=1,
    73	        design_notes="备注",
    74	        annotation_positions='{"_form":{"y":18},"WEIGHT":{"y":-12}}',
    75	        paper_orientation="portrait",
    76	    )
    77	    session.add(form)
    78	    session.flush()
    79	
    80	    ff1 = FormField(form_id=form.id, field_definition_id=fd1.id, order_index=1, default_value="70")
    81	    ff2 = FormField(form_id=form.id, field_definition_id=fd2.id, order_index=2, inline_mark=1)
    82	    session.add_all([ff1, ff2])
    83	    session.flush()
    84	
    85	    visit = Visit(project_id=project.id, name="V1", code="VISIT1", sequence=1)
    86	    session.add(visit)
    87	    session.flush()
    88	
    89	    visit_form = VisitForm(visit_id=visit.id, form_id=form.id, sequence=1)
    90	    session.add(visit_form)
    91	    session.flush()
    92	
    93	    return project
