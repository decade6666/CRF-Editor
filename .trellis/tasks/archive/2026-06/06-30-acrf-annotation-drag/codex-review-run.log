   221	def test_validate_schema_rejects_incomplete_db(tmp_path):
   222	    """缺少核心表时 _validate_schema 应抛出 ValueError。"""
   223	    db_path = tmp_path / "incomplete.db"
   224	    conn = sqlite3.connect(str(db_path))
   225	    conn.execute("CREATE TABLE project (id INTEGER PRIMARY KEY)")
   226	    conn.execute("CREATE TABLE dummy (id INTEGER PRIMARY KEY)")
   227	    conn.commit()
   228	    conn.close()
   229	
   230	    engine = create_engine(f"sqlite:///{db_path}")
   231	    session = Session(engine)
   232	    with pytest.raises(ValueError, match="核心表"):
   233	        _validate_schema(session)
   234	    session.close()
   235	    engine.dispose()
   236	
