    20	def _create_full_project_graph(session: Session, owner_id: int) -> Project:
    21	    project = Project(
    22	        name="源项目",
    23	        version="1.0",
    24	        trial_name="试验A",
    25	        crf_version="v1",
    26	        protocol_number="P-001",
    27	        screening_number_format="SCR-001",
