    62	def _annotation_offsets_by_text(docx_path: Path) -> dict[str, int]:
    63	    tree = _document_xml_tree(docx_path)
    64	    offsets: dict[str, int] = {}
    65	    for anchor in tree.xpath("//wp:anchor", namespaces=NS):
    66	        texts = anchor.xpath(".//wps:txbx//w:t/text()", namespaces=NS)
    67	        if not texts:
    68	            continue
    69	        pos_offsets = anchor.xpath("./wp:positionV/wp:posOffset/text()", namespaces=NS)
    70	        if not pos_offsets:
    71	            continue
    72	        offsets["".join(texts)] = int(pos_offsets[0])
    73	    return offsets
