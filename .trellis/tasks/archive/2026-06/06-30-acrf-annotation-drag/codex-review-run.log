   139	def _upload_db(client, endpoint: str, db_path: Path, token: str):
   140	    """通过 multipart/form-data 上传 .db 文件。"""
   141	    with open(db_path, "rb") as f:
   142	        return client.post(
   143	            endpoint,
   144	            files={"file": ("test.db", f, "application/octet-stream")},
   145	            headers=auth_headers(token),
   146	        )
