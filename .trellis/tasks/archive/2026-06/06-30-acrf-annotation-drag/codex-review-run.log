   152	def test_import_project_db_accepts_authenticated_user(client, engine, tmp_path):
   153	    """普通登录用户也可导入单项目，owner 需重绑到当前用户。"""
   154	    token = login_as(client, "bob")
   155	    db_path = _create_export_db(tmp_path / "export.db", project_count=1)
   156	    resp = _upload_db(client, "/api/projects/import/project-db", db_path, token)
   157	    assert resp.status_code == 200, resp.text
   158	
   159	    data = resp.json()
   160	    with Session(engine) as session:
   161	        bob = session.scalar(select(User).where(User.username == "bob"))
   162	        imported = session.get(Project, data["project_id"])
   163	        assert bob is not None
   164	        assert imported is not None
   165	        assert imported.owner_id == bob.id
   166	        assert imported.screening_number_format == "SCR-001"
   167	
