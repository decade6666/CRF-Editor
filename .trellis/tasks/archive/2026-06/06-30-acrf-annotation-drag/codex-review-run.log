   180	def _parse_form(raw_form: Any, index: int) -> TableFieldForm:
   181	    if not isinstance(raw_form, dict):
   182	        raise ValueError(f"form #{index} must be an object")
   183	    name = str(raw_form.get("name") or raw_form.get("title") or "")
   184	    raw_tables = raw_form.get("tables")
   185	    if not isinstance(raw_tables, list):
   186	        raise ValueError(f"form #{index} tables must be a list")
   187	    return TableFieldForm(name=name, tables=[_parse_table(table) for table in raw_tables])
   188	
   189	
   190	def _parse_table(raw_table: Any) -> list[list[str]]:
   191	    if not isinstance(raw_table, list):
   192	        raise ValueError("table must be a list of rows")
   193	    return [[_normalize_cell_text(cell) for cell in row] for row in raw_table]
   194	
   195	
   196	def _iter_block_items(doc: DocxDocument) -> Iterable[Paragraph | Table]:
   197	    for child in doc.element.body.iterchildren():
   198	        if child.tag == qn("w:p"):
   199	            yield Paragraph(child, doc)
   200	        elif child.tag == qn("w:tbl"):
   201	            yield Table(child, doc)
   202	
   203	
   204	def _extract_table(table: Table) -> list[list[str]]:
   205	    extracted: list[list[str]] = []
   206	    for row in table.rows:
   207	        seen_cells = []
   208	        values: list[str] = []
   209	        for cell in row.cells:
   210	            if any(cell._tc is seen for seen in seen_cells):
   211	                continue
   212	            seen_cells.append(cell._tc)
   213	            values.append(_normalize_cell_text(cell.text))
   214	        extracted.append(values)
   215	    return extracted
   216	
   217	
   218	def _normalize_cell_text(value: Any) -> str:
   219	    return str(value).replace("\r\n", "\n").replace("\r", "\n")
   220	
