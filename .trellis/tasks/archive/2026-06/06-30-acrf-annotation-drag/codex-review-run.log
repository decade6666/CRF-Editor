   189	def test_merge_database_accepts_authenticated_user(client, engine, tmp_path):
   190	    """普通登录用户也可整库合并导入，owner 需重绑到当前用户。"""
   191	    token = login_as(client, "bob")
   192	    db_path = _create_export_db(tmp_path / "export.db", project_count=2)
   193	    resp = _upload_db(client, "/api/projects/import/database-merge", db_path, token)
   194	    assert resp.status_code == 200, resp.text
   195	
   196	    imported_ids = [item["id"] for item in resp.json()["imported"]]
   197	    with Session(engine) as session:
   198	        bob = session.scalar(select(User).where(User.username == "bob"))
   199	        imported_projects = session.scalars(
   200	            select(Project).where(Project.id.in_(imported_ids)).order_by(Project.id)
   201	        ).all()
   202	        assert bob is not None
   203	        assert len(imported_projects) == 2
   204	        assert all(project.owner_id == bob.id for project in imported_projects)
   205	        assert {project.screening_number_format for project in imported_projects} == {"SCR-001", "SCR-002"}
