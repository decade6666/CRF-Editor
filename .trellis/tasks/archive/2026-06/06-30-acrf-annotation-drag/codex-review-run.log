    98	// 安全解析 JSON 响应，处理代理/网关返回非 JSON 内容的情况
    99	async function _safeJsonParse(r) {
   100	  const text = await r.text();
   101	  try {
   102	    return JSON.parse(text);
   103	  } catch {
   104	    throw new Error(`服务器返回非 JSON 格式: ${text.slice(0, 100)}...`);
   105	  }
