    96	def test_copy_project_clones_full_graph(client, engine, tmp_path: Path):
    97	    token = login_as(client, "alice")
    98	
    99	    with Session(engine) as session:
   100	        with session.begin():
   101	            user = session.scalar(select(User).where(User.username == "alice"))
   102	            assert user is not None
   103	            project = _create_full_project_graph(session, user.id)
   104	            logos_dir = tmp_path / "logos"
   105	            logos_dir.mkdir(parents=True, exist_ok=True)
   106	            (logos_dir / "source-logo.png").write_bytes(b"source-logo")
   107	
   108	    from src.config import AppConfig, AuthConfig, StorageConfig
   109	
   110	    test_config = AppConfig(
   111	        auth=AuthConfig(secret_key="test-secret-key-for-testing"),
   112	        storage=StorageConfig(upload_path=str(tmp_path)),
   113	    )
   114	
   115	    with patch("src.services.project_clone_service.get_config", return_value=test_config), \
   116	         patch("src.routers.projects.get_config", return_value=test_config):
   117	        resp = client.post("/api/projects/1/copy", headers=auth_headers(token))
   118	
   119	    assert resp.status_code == 201, resp.text
   120	    copied = resp.json()
   121	    assert copied["name"] == "源项目 (副本)"
   122	    assert copied["id"] != 1
   123	
   124	    with Session(engine) as session:
   125	        projects = session.scalars(select(Project).order_by(Project.id)).all()
   126	        assert len(projects) == 2
   127	        source_project, cloned_project = projects
   128	        assert copied["company_logo_path"] == cloned_project.company_logo_path
   129	        assert cloned_project.owner_id == source_project.owner_id
   130	        assert cloned_project.screening_number_format == source_project.screening_number_format
   131	        assert cloned_project.company_logo_path is not None
   132	        assert cloned_project.company_logo_path != source_project.company_logo_path
   133	
   134	        source_units = session.scalars(select(Unit).where(Unit.project_id == source_project.id)).all()
   135	        cloned_units = session.scalars(select(Unit).where(Unit.project_id == cloned_project.id)).all()
   136	        assert len(source_units) == len(cloned_units) == 1
   137	        assert cloned_units[0].id != source_units[0].id
   138	        assert cloned_units[0].symbol == source_units[0].symbol
   139	
   140	        source_codelists = session.scalars(select(CodeList).where(CodeList.project_id == source_project.id)).all()
   141	        cloned_codelists = session.scalars(select(CodeList).where(CodeList.project_id == cloned_project.id)).all()
   142	        assert len(source_codelists) == len(cloned_codelists) == 1
   143	        assert cloned_codelists[0].id != source_codelists[0].id
   144	
   145	        source_options = session.scalars(select(CodeListOption).where(CodeListOption.codelist_id == source_codelists[0].id)).all()
   146	        cloned_options = session.scalars(select(CodeListOption).where(CodeListOption.codelist_id == cloned_codelists[0].id)).all()
   147	        assert len(source_options) == len(cloned_options) == 2
   148	        assert {o.decode for o in cloned_options} == {"男", "女"}
   149	
   150	        source_defs = session.scalars(select(FieldDefinition).where(FieldDefinition.project_id == source_project.id).order_by(FieldDefinition.order_index)).all()
   151	        cloned_defs = session.scalars(select(FieldDefinition).where(FieldDefinition.project_id == cloned_project.id).order_by(FieldDefinition.order_index)).all()
   152	        assert len(source_defs) == len(cloned_defs) == 2
   153	        assert all(a.id != b.id for a, b in zip(source_defs, cloned_defs))
   154	        assert cloned_defs[0].unit_id == cloned_units[0].id
   155	        assert cloned_defs[1].codelist_id == cloned_codelists[0].id
   156	
   157	        source_forms = session.scalars(select(Form).where(Form.project_id == source_project.id)).all()
   158	        cloned_forms = session.scalars(select(Form).where(Form.project_id == cloned_project.id)).all()
   159	        assert len(source_forms) == len(cloned_forms) == 1
   160	        assert cloned_forms[0].id != source_forms[0].id
   161	        assert cloned_forms[0].domain == "DM"
   162	        assert cloned_forms[0].annotation_positions == source_forms[0].annotation_positions
   163	        assert cloned_forms[0].paper_orientation == "portrait"
   164	
   165	        cloned_form_fields = session.scalars(select(FormField).where(FormField.form_id == cloned_forms[0].id).order_by(FormField.order_index)).all()
   166	        assert len(cloned_form_fields) == 2
   167	        assert cloned_form_fields[0].field_definition_id == cloned_defs[0].id
   168	        assert cloned_form_fields[1].field_definition_id == cloned_defs[1].id
   169	
   170	        source_visits = session.scalars(select(Visit).where(Visit.project_id == source_project.id)).all()
   171	        cloned_visits = session.scalars(select(Visit).where(Visit.project_id == cloned_project.id)).all()
   172	        assert len(source_visits) == len(cloned_visits) == 1
   173	        assert cloned_visits[0].id != source_visits[0].id
   174	
   175	        cloned_visit_forms = session.scalars(select(VisitForm).where(VisitForm.visit_id == cloned_visits[0].id)).all()
   176	        assert len(cloned_visit_forms) == 1
   177	        assert cloned_visit_forms[0].form_id == cloned_forms[0].id
   178	
   179	        assert (tmp_path / "logos" / source_project.company_logo_path).read_bytes() == b"source-logo"
   180	        assert (tmp_path / "logos" / cloned_project.company_logo_path).read_bytes() == b"source-logo"
