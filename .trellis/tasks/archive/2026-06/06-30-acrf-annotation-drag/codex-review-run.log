    34	def _create_export_db(
    35	    db_path: Path,
    36	    project_count: int = 1,
    37	    with_children: bool = False,
    38	    project_names: list | None = None,
    39	    annotation_positions: str | None = None,
    40	) -> Path:
    41	    """创建模拟导出的 .db 文件，包含完整 ORM schema。"""
    42	    engine = create_engine(f"sqlite:///{db_path}")
    43	
    44	    @event.listens_for(engine, "connect")
    45	    def _fk(dbapi_conn, _):
    46	        dbapi_conn.execute("PRAGMA foreign_keys = ON")
    47	
    48	    Base.metadata.create_all(engine)
    49	
    50	    with Session(engine) as session:
    51	        with session.begin():
    52	            user = User(username="export_user")
    53	            session.add(user)
    54	            session.flush()
    55	
    56	            names = project_names or [f"项目{i + 1}" for i in range(project_count)]
    57	            for i, name in enumerate(names):
    58	                project = Project(name=name, version="1.0", owner_id=user.id, screening_number_format=f"SCR-{i + 1:03d}")
    59	                session.add(project)
    60	                session.flush()
    61	
