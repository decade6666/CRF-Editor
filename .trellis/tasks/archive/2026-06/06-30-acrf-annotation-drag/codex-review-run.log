    76	def _assert_anchors_wrapped_in_drawing(docx_path: Path) -> None:
    77	    """每个 wp:anchor 必须包在 w:drawing 里、且 drawing 在 w:r 内。
    78	
    79	    缺少 w:drawing 包裹会产生非法 OOXML（wp:anchor 直挂 w:r），
    80	    导致 Word 判定文档损坏、无法打开。
    81	    """
    82	    tree = _document_xml_tree(docx_path)
    83	    anchors = tree.xpath("//wp:anchor", namespaces=NS)
    84	    assert anchors, "aCRF 应至少包含一个浮动注释 anchor"
    85	    for anchor in anchors:
    86	        drawing = anchor.getparent()
    87	        assert drawing is not None and drawing.tag == f"{{{NS['w']}}}drawing"
    88	        run = drawing.getparent()
    89	        assert run is not None and run.tag == f"{{{NS['w']}}}r"
