   101	def _create_visit_with_forms(session: Session, owner_id: int) -> tuple[int, list[int]]:
   102	    project = Project(name="复制访视项目", version="1.0", owner_id=owner_id, order_index=1)
   103	    session.add(project)
   104	    session.flush()
   105	
   106	    visit = Visit(project_id=project.id, name="基线访视", code="VISIT_COPY", sequence=1)
   107	    session.add(visit)
   108	    session.flush()
   109	
   110	    form_ids = []
   111	    for idx in range(1, 3):
   112	        form = Form(project_id=project.id, name=f"表单{idx}", code=f"FORM_COPY_{idx}", order_index=idx)
   113	        session.add(form)
   114	        session.flush()
   115	        form_ids.append(form.id)
   116	        session.add(VisitForm(visit_id=visit.id, form_id=form.id, sequence=idx))
   117	
   118	    session.flush()
   119	    session.commit()
   120	    return visit.id, form_ids
