    20	function extractFunction(name, source = formDesignerSource) {
    21	  const start = source.indexOf(`function ${name}(`);
    22	  assert.notEqual(start, -1, `function ${name} should exist`);
    23	
    24	  const argsStart = source.indexOf('(', start);
    25	  const argsEnd = source.indexOf(')', argsStart);
    26	  const bodyStart = source.indexOf('{', argsEnd);
    27	  assert.notEqual(bodyStart, -1, `function ${name} should have a body`);
    28	
    29	  let depth = 0;
    30	  let bodyEnd = -1;
    31	  for (let index = bodyStart; index < source.length; index += 1) {
    32	    const char = source[index];
    33	    if (char === '{') depth += 1;
    34	    if (char === '}') {
    35	      depth -= 1;
    36	      if (depth === 0) {
    37	        bodyEnd = index;
    38	        break;
    39	      }
    40	    }
    41	  }
    42	
    43	  assert.notEqual(bodyEnd, -1, `function ${name} should close its body`);
    44	  return {
    45	    params: source.slice(argsStart + 1, argsEnd),
    46	    body: source.slice(bodyStart + 1, bodyEnd),
    47	  };
    48	}
    49	
    50	function compileFunction(name, dependencies = {}, source = formDesignerSource) {
    51	  const { params, body } = extractFunction(name, source);
    52	  const dependencyNames = Object.keys(dependencies);
    53	  const dependencyValues = Object.values(dependencies);
    54	  const factory = new Function(...dependencyNames, `return function ${name}(${params}) {${body}}`);
    55	  return factory(...dependencyValues);
    56	}
