   245	def _cell_mismatch(
   246	    form_index: int,
   247	    form_name: str,
   248	    table_index: int,
   249	    row_index: int,
   250	    cell_index: int,
   251	    preview: str | None,
   252	    export: str | None,
   253	) -> CellMismatch:
   254	    if preview is None:
   255	        kind = "missing_preview_cell"
   256	    elif export is None:
   257	        kind = "missing_export_cell"
   258	    else:
   259	        kind = "text"
   260	    return CellMismatch(form_index, form_name, table_index, row_index, cell_index, kind, preview, export)
