    66	const _cache = new Map(); // key → { data, ts }
    67	const _pending = new Map(); // key → Promise（去重并发请求）
    68	
    69	// 按URL前缀清除缓存
    70	function invalidateCache(urlPrefix) {
    71	  for (const key of _cache.keys()) {
    72	    if (key.startsWith(urlPrefix)) _cache.delete(key);
    73	  }
    74	  for (const key of _pending.keys()) {
    75	    if (key.startsWith(urlPrefix)) _pending.delete(key);
    76	  }
    77	}
    78	
    79	// 清除全部缓存
    80	function clearAllCache() {
    81	  _cache.clear();
    82	  _pending.clear();
    83	}
    84	
    85	// 数据变更后自动失效相关缓存
    86	function _autoInvalidate(url) {
    87	  // /api/projects/1/field-definitions → 失效 /api/projects/1/
    88	  // /api/projects/1 → 失效 /api/projects
    89	  const parts = url.split('/');
    90	  if (parts.length >= 4) {
    91	    // 失效到 /api/projects/{id}/ 级别
    92	    invalidateCache(parts.slice(0, 4).join('/'));
    93	  }
    94	  // 同时失效完整URL
    95	  invalidateCache(url);
